# =============================================
# AURALIS — Environment Variables
# LOCAL:  copy to .env  →  node start.js
# RENDER: add these in the dashboard manually
# =============================================

# Server
PORT=4000
NODE_ENV=development

# JWT — change to any long random string
JWT_SECRET=auralis-change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Groq AI — free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# YouTube API — free at console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database
# Local: leave empty (uses SQLite automatically)
# Render/Neon: paste your connection string here
DATABASE_URL=
